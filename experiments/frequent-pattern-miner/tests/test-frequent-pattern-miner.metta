!(let $result2
    (collapse (frequency-pattern-miner &dbspace $x &cndpspace1 &conjspace1 5 0 True))
    (assertEqual $result2 ((supportOf (, (Inheritance $_232438 sodaDrinker) (Inheritance $_232438 ugly)) 5)
                            (supportOf (, (Inheritance $_232360 sodaDrinker) (Inheritance $_232360 woman)) 5)
                            (supportOf (, (Inheritance $_232282 sodaDrinker) (Inheritance $_232282 man)) 5)
                            (supportOf (, (Inheritance $_232204 sodaDrinker) (Inheritance $_232204 human)) 10)
                            (supportOf (, (Inheritance $_232126 sodaDrinker) (Inheritance $_232126 $_232156)) 35)
                            (supportOf (, (Inheritance $_232048 ugly) (Inheritance $_232048 woman)) 5)
                            (supportOf (, (Inheritance $_231970 ugly) (Inheritance $_231970 man)) 5)
                            (supportOf (, (Inheritance $_231892 ugly) (Inheritance $_231892 human)) 10)
                            (supportOf (, (Inheritance $_231814 ugly) (Inheritance $_231814 $_231844)) 35)
                            (supportOf (, (Inheritance $_231736 woman) (Inheritance $_231736 human)) 10)
                            (supportOf (, (Inheritance $_231658 woman) (Inheritance $_231658 $_231688)) 30)
                            (supportOf (, (Inheritance $_231580 man) (Inheritance $_231580 human)) 10)
                            (supportOf (, (Inheritance $_231502 man) (Inheritance $_231502 $_231532)) 30)
                            (supportOf (, (Inheritance $_231424 human) (Inheritance $_231424 $_231454)) 60)
                            (supportOf (, (Inheritance $_231346 $_231352) (Inheritance $_231346 $_231376)) 190)
                            (supportOf (, (Inheritance $_231268 $_231274) (Inheritance $_231292 $_231274)) 800)))
)
!(let $result1
